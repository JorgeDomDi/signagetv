# Copia este archivo como .env (NO se subir a git) y editalo con tus valores reales.

# ====== MySQL (apunta al MySQL del host del VPS, no levantamos contenedor) ======
# host.docker.internal es el alias para llegar al host desde Docker.
DB_URL=jdbc:mysql://host.docker.internal:3306/signagetv?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=signagetv
DB_PASS=cambia_esto_a_la_pass_que_pusiste_en_mysql

# ====== Backend ======
# IMPORTANTE: usa un secreto largo (64+ chars). Generar con: openssl rand -hex 64
JWT_SECRET=cambia_esto_a_un_string_aleatorio_de_al_menos_64_caracteres_para_produccion

# URL pública por la que se va a alcanzar al backend.
# En producción: http://signage.tu-dominio.com
PUBLIC_BASE_URL=http://localhost

# Origenes CORS permitidos (coma-separados)
CORS_ORIGINS=http://localhost:5173

# Perfil de Spring (prod | dev). dev crea usuarios seed local1/local2 con password123
SPRING_PROFILES_ACTIVE=prod

# Puerto en el host donde escucha nginx (por defecto 8082 para no chocar con el 80 si está ocupado)
HTTP_PORT=8082
