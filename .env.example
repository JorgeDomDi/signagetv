# Renombra este archivo a .env y ajusta los valores antes de desplegar.

# MySQL
MYSQL_ROOT_PASSWORD=cambia_esto_root
MYSQL_DATABASE=signagetv
MYSQL_USER=signagetv
MYSQL_PASSWORD=cambia_esto_usuario

# Backend
# IMPORTANTE: usa un secreto largo (64+ chars). Generar con: openssl rand -hex 64
JWT_SECRET=cambia_esto_a_un_string_largo_aleatorio_de_al_menos_64_caracteres_para_produccion

# URL pública por la que las TVs y el admin alcanzan al backend.
# En produccion: https://signage.tu-dominio.com
PUBLIC_BASE_URL=http://localhost

# Origenes CORS permitidos (coma-separados)
CORS_ORIGINS=http://localhost,http://localhost:5173

# Perfil de Spring (prod | dev). dev crea usuarios seed local1/local2 con password123
SPRING_PROFILES_ACTIVE=prod
